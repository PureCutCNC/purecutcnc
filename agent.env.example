# Copy this file to .env.agent and set the token locally. Do not commit .env.agent.
DEEPSEEK_API_KEY=

# DeepSeek model identifiers used through Claude Code's Anthropic-compatible endpoint.
DEEPSEEK_PRO_MODEL=deepseek-v4-pro
DEEPSEEK_FLASH_MODEL=deepseek-v4-flash

# Optional worker defaults.
DEEPSEEK_EFFORT_LEVEL=max
DEEPSEEK_MAX_BUDGET_USD=1.00
