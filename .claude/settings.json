{
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "if": "Bash(git*)",
            "command": "bash \"${CLAUDE_PROJECT_DIR:-.}/.claude/hooks/block-default-branch-commit.sh\"",
            "statusMessage": "Checking branch before commit"
          }
        ]
      }
    ]
  }
}
