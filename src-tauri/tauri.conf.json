{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "PureCutCNC",
  "version": "../package.json",
  "identifier": "com.purecutcnc.purecutcnc",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:1420",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run tauri:icon && npm run build"
  },
  "app": {
    "windows": [
      {
        "title": "PureCutCNC",
        "width": 1280,
        "height": 800,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
