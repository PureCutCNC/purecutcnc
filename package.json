{
  "name": "PureCutCNC",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "npm run lint && npx tsx scripts/build-icon-sprite.ts && tsc -b && npm test && vite build",
    "lint": "eslint src vite.config.ts scripts/run-tests.ts scripts/check-license-headers.ts",
    "lint:scripts": "eslint scripts",
    "preview": "vite preview",
    "sync-icons": "npx tsx scripts/build-icon-sprite.ts",
    "test": "npx tsx scripts/check-license-headers.ts && npx tsx scripts/run-tests.ts",
    "test:agent": "bash scripts/test-claude-deepseek-agent.sh",
    "test:e2e": "playwright test",
    "check:headers": "npx tsx scripts/check-license-headers.ts",
    "tauri": "tauri",
    "tauri:icon": "npx tauri icon ./app-icon.png",
    "tauri:dev": "tauri dev",
    "tauri:build": "tauri build"
  },
  "dependencies": {
    "@tauri-apps/api": "~2.10.1",
    "@tauri-apps/plugin-dialog": "^2.7.0",
    "@tauri-apps/plugin-fs": "^2.5.0",
    "@tauri-apps/plugin-opener": "^2.5.0",
    "@types/three": "^0.183.1",
    "clipper-lib": "^6.4.2",
    "manifold-3d": "^3.3.2",
    "pdf-lib": "^1.17.1",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "three": "^0.183.2",
    "zod": "^4.3.6",
    "zustand": "^5.0.12"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@playwright/test": "^1.61.0",
    "@tauri-apps/cli": "^2.10.1",
    "@types/node": "^24.12.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "autoprefixer": "^10.4.27",
    "eslint": "^9.39.4",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.4.0",
    "postcss": "^8.5.8",
    "tailwindcss": "^4.2.2",
    "tsx": "^4.21.0",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.57.0",
    "vite": "^8.0.1"
  }
}
